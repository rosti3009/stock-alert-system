API_PROVIDER=polygon
API_KEY=your_api_key_here

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SCAN_MODE=daily
USE_DYNAMIC_SYMBOLS=true
MAX_SYMBOLS_PER_SCAN=30
MIN_PRICE=5
MIN_AVG_VOLUME=500000
BATCH_SIZE=5
REQUEST_DELAY_SECONDS=1
SCAN_SYMBOL_TIMEOUT_SECONDS=45
DAILY_SCAN_HOUR=23
DAILY_SCAN_MINUTE=30
SCAN_INTERVAL_MINUTES=30
RUN_SCAN_ON_STARTUP=false

MAX_RISK_PERCENT=8
MIN_RR_RATIO=2
STOP_LOSS_BUFFER=0.98
ATR_STOP_MULTIPLIER=1.5

RSI_BUY_MIN=50
RSI_BUY_MAX=70
RSI_SELL_MAX=45
BUY_TELEGRAM_MIN_SCORE=75
SELL_TELEGRAM_MIN_SCORE=70
ALERT_COOLDOWN_MINUTES=240

DB_PATH=stock_alerts.db
